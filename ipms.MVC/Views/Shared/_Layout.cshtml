@{
    var email = Context.Session.GetString(SessionKeys.Email);
    var isLoggedIn = !string.IsNullOrEmpty(Context.Session.GetString(SessionKeys.AccessToken));
    var roles = (Context.Session.GetString(SessionKeys.Roles) ?? "").Split(',');
    var isUnderwriter = roles.Contains(Roles.Underwriter);
    var isCustomer = roles.Contains(Roles.Customer);
    var isAdmin = roles.Contains(Roles.Admin);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IPMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-ipms sticky-top mb-4">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <svg width="28" height="28" viewBox="0 0 32 32" aria-hidden="true">
                    <path d="M4 10 L12 4 L12 15 L4 21 Z" fill="#14226b" />
                    <path d="M19 11 L28 5 L28 16 L19 22 Z" fill="#33b98f" />
                </svg>
                IPMS
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav"
                    aria-controls="nav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav me-auto">
                    @if (isLoggedIn)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Products" asp-action="Index">Products</a>
                        </li>

                        @if (isCustomer)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Quotes" asp-action="Index">My Quotes</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Policies" asp-action="Index">My Policies</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Claims" asp-action="Index">My Claims</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Customer" asp-action="Create">My Profile</a>
                            </li>
                        }

                        @if (isUnderwriter)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Underwriting" asp-action="Index">Review Quotes</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Claims" asp-action="Review">Review Claims</a>
                            </li>
                        }

                        @if (isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Users">Users</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="CreateStaff">Create Staff</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="CreateProduct">Add Product</a>
                            </li>
                        }
                    }
                </ul>

                <ul class="navbar-nav align-items-lg-center">
                    @if (isLoggedIn)
                    {
                        <li class="nav-item">
                            <span class="navbar-text me-3">@email</span>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="btn btn-sm btn-outline-primary">Sign out</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">Sign in</a>
                        </li>
                        <li class="nav-item ms-lg-2">
                            <a class="btn btn-sm btn-primary" asp-controller="Account" asp-action="Signup">Get Started</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main role="main" class="container">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container d-flex justify-content-between flex-wrap">
            <span>&copy; @DateTime.UtcNow.Year IPMS &mdash; Insurance Policy Management System</span>
            <span>Reduce risk and keep life good.</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
