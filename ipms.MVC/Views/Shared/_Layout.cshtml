@{
    var email = Context.Session.GetString(SessionKeys.Email);
    var isLoggedIn = !string.IsNullOrEmpty(Context.Session.GetString(SessionKeys.AccessToken));
    var roles = (Context.Session.GetString(SessionKeys.Roles) ?? "").Split(',');
    var isUnderwriter = roles.Contains(Roles.Underwriter);
    var isCustomer = roles.Contains(Roles.Customer);
    var isAdmin = roles.Contains(Roles.Admin);
    var isAgent = roles.Contains(Roles.InsuranceAgent);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IPMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    @* Serif headings + sans body, matching the reference design. Falls back to
       Georgia / system fonts if there is no internet. *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-ipms sticky-top">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <svg width="26" height="26" viewBox="0 0 32 32" aria-hidden="true">
                    <path d="M16 3 4 8v8c0 7 5 11 12 13 7-2 12-6 12-13V8z" fill="#2ec4a6" />
                    <path d="M16 3 4 8v8c0 7 5 11 12 13z" fill="#0d3b52" />
                </svg>
                IPMS
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav"
                    aria-controls="nav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="nav">
                @* Centre links, like the reference nav. *@
                <ul class="navbar-nav mx-lg-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>

                    @if (isLoggedIn)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Products" asp-action="Index">Products</a>
                        </li>

                        @if (isCustomer)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Quotes" asp-action="Index">My Quotes</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Policies" asp-action="Index">My Policies</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Claims" asp-action="Index">My Claims</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Customer" asp-action="Index">Profile</a>
                            </li>
                        }

                        @if (isAgent)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Products" asp-action="Create">Add Product</a>
                            </li>
                        }

                        @if (isUnderwriter)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Underwriting" asp-action="Index">Review Quotes</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Claims" asp-action="Review">Review Claims</a>
                            </li>
                        }

                        @if (isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Users">Users</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="CreateStaff">Create Staff</a>
                            </li>
                        }
                    }
                </ul>

                <ul class="navbar-nav align-items-lg-center">
                    @if (isLoggedIn)
                    {
                        <li class="nav-item">
                            <span class="navbar-text me-3">@email</span>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="btn btn-sm btn-ink">Sign out</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-sm btn-ink me-2" asp-controller="Account" asp-action="Login">Sign in</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-sm btn-teal" asp-controller="Account" asp-action="Signup">Sign Up</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main role="main">
        @* Landing page renders full-width; every other page sits in a container. *@
        @if (ViewData["FullWidth"] is true)
        {
            @if (TempData["Success"] != null)
            {
                <div class="container pt-3"><div class="alert alert-success">@TempData["Success"]</div></div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="container pt-3"><div class="alert alert-danger">@TempData["Error"]</div></div>
            }
            @RenderBody()
        }
        else
        {
            <div class="container py-4">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">@TempData["Error"]</div>
                }

                @RenderBody()
            </div>
        }
    </main>

    <footer class="site-footer">
        <div class="container d-flex justify-content-between flex-wrap">
            <span>&copy; @DateTime.UtcNow.Year IPMS &mdash; Insurance Policy Management System</span>
            <span>Life more relaxed with smart insurance.</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
