@* Shared behaviour for every .toggle-pw button: reveals/hides the password and
   swaps the open eye for the crossed-out eye. *@
<script>
    document.querySelectorAll('.toggle-pw').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var input = document.getElementById(this.dataset.target);
            if (!input) return;

            var revealed = input.type === 'text';
            input.type = revealed ? 'password' : 'text';

            var open = this.querySelector('.eye-open');
            var closed = this.querySelector('.eye-closed');
            if (open && closed) {
                open.classList.toggle('d-none', !revealed);
                closed.classList.toggle('d-none', revealed);
            }
            this.setAttribute('aria-label', revealed ? 'Show password' : 'Hide password');
        });
    });
</script>
