@model QuotesDto
@{
    ViewData["Title"] = "My quotes";
}

<div class="page-head">
    <div>
        <h2>My quotes</h2>
        <p class="page-sub">Click a quote to see its full details.</p>
    </div>
    <a class="btn btn-teal" asp-controller="Products" asp-action="Index">Browse products</a>
</div>

@if (Model.Total == 0)
{
    <div class="empty-state">
        <div class="es-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M6 2h9l5 5v15H6z" opacity=".25" /><path d="M8 11h8v1.6H8zm0 4h8v1.6H8z" />
            </svg>
        </div>
        <h5>No quotes yet</h5>
        <p class="mb-0">
            <a asp-controller="Products" asp-action="Index">Browse products</a> to request your first quote.
        </p>
    </div>
}
else
{
    <div class="panel">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Quote #</th>
                    <th>Product</th>
                    <th>Coverage</th>
                    <th>Premium</th>
                    <th>Valid until</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var quote in Model.Quotes)
                {
                    <tr class="detail-row" style="cursor:pointer" data-quote-id="@quote.Id">
                        <td>@quote.QuoteNumber</td>
                        <td>@quote.ProductName</td>
                        <td>@quote.CoverageAmount.ToString("N0")</td>
                        <td>@quote.PremiumAmount.ToString("N2")</td>
                        <td>@quote.ValidUntil.ToString("yyyy-MM-dd")</td>
                        <td>
                            @{
                                var qcls = quote.Status switch
                                {
                                    QuoteStatus.Approved => "pill pill-green",
                                    QuoteStatus.Rejected => "pill pill-red",
                                    QuoteStatus.Expired => "pill pill-grey",
                                    QuoteStatus.AcceptedByCustomer => "pill pill-blue",
                                    _ => "pill pill-amber"
                                };
                            }
                            <span class="@qcls">@quote.Status</span>
                        </td>
                        <td class="text-end text-nowrap" onclick="event.stopPropagation();">
                            @if (quote.Status == QuoteStatus.Requested)
                            {
                                <form asp-action="Accept" asp-route-id="@quote.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-teal">Accept</button>
                                </form>
                            }
                            else if (quote.Status == QuoteStatus.AcceptedByCustomer)
                            {
                                <small style="color:var(--body)">Awaiting underwriter</small>
                            }
                            else if (quote.Status == QuoteStatus.Approved)
                            {
                                <a asp-controller="Policies" asp-action="Index" class="btn btn-sm btn-outline-primary">
                                    View policy
                                </a>
                            }

                            @if (quote.Status == QuoteStatus.Requested || quote.Status == QuoteStatus.AcceptedByCustomer)
                            {
                                <form asp-action="Cancel" asp-route-id="@quote.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Cancel this quote?');">
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">Cancel</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="modal fade" id="detailModal" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Quote details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="detailModalBody"></div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.querySelectorAll('.detail-row').forEach(function (row) {
            row.addEventListener('click', function () {
                var body = document.getElementById('detailModalBody');
                body.innerHTML = '<p class="text-muted">Loading...</p>';
                new bootstrap.Modal(document.getElementById('detailModal')).show();

                fetch('/Quotes/Details/' + this.dataset.quoteId)
                    .then(function (r) { return r.text(); })
                    .then(function (html) { body.innerHTML = html; })
                    .catch(function () {
                        body.innerHTML = '<p class="text-danger">Could not load this quote.</p>';
                    });
            });
        });
    </script>
}
