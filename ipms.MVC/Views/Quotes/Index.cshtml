@model QuotesDto
@{
    ViewData["Title"] = "My quotes";
}

<h2>My quotes</h2>

@if (Model.Total == 0)
{
    <p class="text-muted">
        You have no quotes yet.
        <a asp-controller="Products" asp-action="Index">Browse products</a> to request one.
    </p>
}
else
{
    <p class="text-muted">Click a quote to see its full details.</p>

    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Quote #</th>
                <th>Product</th>
                <th>Coverage</th>
                <th>Premium</th>
                <th>Valid until</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var quote in Model.Quotes)
            {
                <tr class="detail-row" style="cursor:pointer" data-quote-id="@quote.Id">
                    <td class="fw-semibold text-decoration-underline">@quote.QuoteNumber</td>
                    <td>@quote.ProductName</td>
                    <td>@quote.CoverageAmount.ToString("N0")</td>
                    <td>@quote.PremiumAmount.ToString("N2")</td>
                    <td>@quote.ValidUntil.ToString("yyyy-MM-dd")</td>
                    <td><span class="badge bg-secondary">@quote.Status</span></td>
                    <td class="text-nowrap" onclick="event.stopPropagation();">
                        @if (quote.Status == QuoteStatus.Requested)
                        {
                            <form asp-action="Accept" asp-route-id="@quote.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-success">Accept</button>
                            </form>
                        }
                        else if (quote.Status == QuoteStatus.AcceptedByCustomer)
                        {
                            <small class="text-muted me-2">Waiting for underwriter</small>
                        }
                        else if (quote.Status == QuoteStatus.Approved)
                        {
                            <a asp-controller="Policies" asp-action="Index" class="btn btn-sm btn-outline-primary">
                                View policy
                            </a>
                        }

                        @* The customer can withdraw a quote until it's decided. *@
                        @if (quote.Status == QuoteStatus.Requested || quote.Status == QuoteStatus.AcceptedByCustomer)
                        {
                            <form asp-action="Cancel" asp-route-id="@quote.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Cancel this quote?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Cancel</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="modal fade" id="detailModal" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Quote details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="detailModalBody"></div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.querySelectorAll('.detail-row').forEach(function (row) {
            row.addEventListener('click', function () {
                var body = document.getElementById('detailModalBody');
                body.innerHTML = '<p class="text-muted">Loading...</p>';
                new bootstrap.Modal(document.getElementById('detailModal')).show();

                fetch('/Quotes/Details/' + this.dataset.quoteId)
                    .then(function (r) { return r.text(); })
                    .then(function (html) { body.innerHTML = html; })
                    .catch(function () {
                        body.innerHTML = '<p class="text-danger">Could not load this quote.</p>';
                    });
            });
        });
    </script>
}
