@model QuoteDto

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h4 class="mb-1">@Model.QuoteNumber</h4>
        <div class="text-muted">@Model.ProductName</div>
    </div>
    <span class="badge bg-secondary fs-6">@Model.Status</span>
</div>

<dl class="row mb-0">
    <dt class="col-5">Coverage amount</dt>
    <dd class="col-7">@Model.CoverageAmount.ToString("N2")</dd>

    <dt class="col-5">Premium amount</dt>
    <dd class="col-7">@Model.PremiumAmount.ToString("N2")</dd>

    <dt class="col-5">Quoted on</dt>
    <dd class="col-7">@Model.QuoteDate.ToString("yyyy-MM-dd")</dd>

    <dt class="col-5">Valid until</dt>
    <dd class="col-7">@Model.ValidUntil.ToString("yyyy-MM-dd")</dd>

    <dt class="col-5">Requested</dt>
    <dd class="col-7">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
</dl>
