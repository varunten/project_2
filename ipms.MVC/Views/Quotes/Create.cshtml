@model CreateQuoteDto
@{
    ViewData["Title"] = "Request a quote";
}

<div class="page-head"><div><h2>Request a quote</h2></div></div>

@if (ViewBag.ProductName != null)
{
    <p class="text-muted">Product: <strong>@ViewBag.ProductName</strong></p>
}

<div class="row">
    <div class="col-md-5">
        <form asp-action="Create" method="post" class="form-panel">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <input type="hidden" asp-for="ProductId" />

            <div class="mb-3">
                <label asp-for="CoverageAmount" class="form-label">Coverage amount</label>
                <input asp-for="CoverageAmount" class="form-control" />
                <span asp-validation-for="CoverageAmount" class="text-danger"></span>
                <div class="form-text">
                    The premium is scaled from the product's base premium by how much
                    coverage you ask for.
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Request quote</button>
            <a asp-controller="Products" asp-action="Index" class="btn btn-link">Cancel</a>
        </form>
    </div>
</div>
