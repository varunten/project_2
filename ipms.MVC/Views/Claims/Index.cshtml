@model ClaimsDto
@{
    ViewData["Title"] = "My claims";
}

<h2>My claims</h2>

@if (Model.Total == 0)
{
    <p class="text-muted">
        You have not filed any claims. You can file one from
        <a asp-controller="Policies" asp-action="Index">your policies</a>.
    </p>
}
else
{
    <p class="text-muted">Click a claim to see its details and documents.</p>

    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Claim #</th>
                <th>Incident date</th>
                <th>Amount</th>
                <th>Approved</th>
                <th>Reason</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var claim in Model.Claims)
            {
                <tr class="detail-row" style="cursor:pointer" data-claim-id="@claim.Id">
                    <td class="fw-semibold text-decoration-underline">@claim.ClaimNumber</td>
                    <td>@claim.IncidentDate.ToString("yyyy-MM-dd")</td>
                    <td>@claim.ClaimAmount.ToString("N2")</td>
                    <td>@(claim.ApprovedAmount?.ToString("N2") ?? "-")</td>
                    <td>@claim.Reason</td>
                    <td>
                        @if (claim.Status == ClaimStatus.Approved)
                        {
                            <span class="badge bg-success">@claim.Status</span>
                        }
                        else if (claim.Status == ClaimStatus.Rejected)
                        {
                            <span class="badge bg-danger">@claim.Status</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@claim.Status</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="modal fade" id="detailModal" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Claim details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="detailModalBody"></div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.querySelectorAll('.detail-row').forEach(function (row) {
            row.addEventListener('click', function () {
                var body = document.getElementById('detailModalBody');
                body.innerHTML = '<p class="text-muted">Loading...</p>';
                new bootstrap.Modal(document.getElementById('detailModal')).show();

                fetch('/Claims/Details/' + this.dataset.claimId)
                    .then(function (r) { return r.text(); })
                    .then(function (html) { body.innerHTML = html; })
                    .catch(function () {
                        body.innerHTML = '<p class="text-danger">Could not load this claim.</p>';
                    });
            });
        });
    </script>
}
