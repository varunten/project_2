@model ClaimsDto
@{
    ViewData["Title"] = "Review claims";
}

<h2>Claims</h2>
<p class="text-muted">Approving a claim settles it for the full claimed amount.</p>

@if (Model.Total == 0)
{
    <p class="text-muted">No claims have been filed.</p>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Claim #</th>
                <th>Incident</th>
                <th>Amount</th>
                <th>Reason</th>
                <th>Status</th>
                <th>Decision</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var claim in Model.Claims)
            {
                <tr>
                    <td>@claim.ClaimNumber</td>
                    <td>@claim.IncidentDate.ToString("yyyy-MM-dd")</td>
                    <td>@claim.ClaimAmount.ToString("N2")</td>
                    <td>@claim.Reason</td>
                    <td><span class="badge bg-secondary">@claim.Status</span></td>
                    <td>
                        @if (claim.Status == ClaimStatus.Submitted || claim.Status == ClaimStatus.UnderReview)
                        {
                            <form asp-action="Decide" method="post" class="d-flex gap-2">
                                <input type="hidden" name="id" value="@claim.Id" />
                                <input type="text" name="notes" class="form-control form-control-sm"
                                       placeholder="Notes" style="max-width:180px" />
                                <button type="submit" name="status" value="@((int)ClaimStatus.Approved)"
                                        class="btn btn-sm btn-success">Approve</button>
                                <button type="submit" name="status" value="@((int)ClaimStatus.Rejected)"
                                        class="btn btn-sm btn-outline-danger">Reject</button>
                            </form>
                        }
                        else
                        {
                            <small class="text-muted">Settled @claim.SettledDate?.ToString("yyyy-MM-dd")</small>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
