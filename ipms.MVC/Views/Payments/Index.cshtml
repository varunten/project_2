@model PremiumPaymentsDto
@{
    ViewData["Title"] = "Premium payments";
    var policyId = (Guid)ViewBag.PolicyId;
}

<div class="page-head">
    <div>
        <h2>Premium payments</h2>
        <p class="page-sub"><a asp-controller="Policies" asp-action="Index">&larr; Back to my policies</a></p>
    </div>
</div>

@if (Model.Total == 0)
{
    <div class="empty-state"><h5>No installments yet</h5><p class="mb-0">Nothing has been generated for this policy.</p></div>
}
else
{
    <div class="panel">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Installment</th>
                <th>Premium</th>
                <th>Penalty</th>
                <th>Due date</th>
                <th>Paid on</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var payment in Model.Payments)
            {
                var amountDue = payment.PremiumAmount + payment.PenaltyAmount;
                <tr>
                    <td>@payment.InstallmentNumber</td>
                    <td>@payment.PremiumAmount.ToString("N2")</td>
                    <td>@payment.PenaltyAmount.ToString("N2")</td>
                    <td>@payment.DueDate.ToString("yyyy-MM-dd")</td>
                    <td>@(payment.PaidDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                    <td>
                        @if (payment.PaymentStatus == PremiumPaymentStatus.Success)
                        {
                            <span class="badge bg-success">@payment.PaymentStatus</span>
                        }
                        else if (payment.PaymentStatus == PremiumPaymentStatus.Late)
                        {
                            <span class="badge bg-warning text-dark">@payment.PaymentStatus</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@payment.PaymentStatus</span>
                        }
                    </td>
                    <td>
                        @if (payment.PaymentStatus != PremiumPaymentStatus.Success
                             && payment.PaymentStatus != PremiumPaymentStatus.Late)
                        {
                            <form asp-action="Pay" method="post" class="d-flex gap-2">
                                <input type="hidden" name="id" value="@payment.Id" />
                                <input type="hidden" name="policyId" value="@policyId" />
                                <input type="hidden" name="amount" value="@amountDue" />
                                <button type="submit" class="btn btn-sm btn-primary">
                                    Pay @amountDue.ToString("N2")
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    </div>
}
