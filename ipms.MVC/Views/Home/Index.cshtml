@{
    ViewData["Title"] = "Home";
    var isLoggedIn = !string.IsNullOrEmpty(Context.Session.GetString(SessionKeys.AccessToken));
}

<section class="hero">
    <div class="row align-items-center g-5">
        <div class="col-lg-6">
            <h1>Reduce risk and keep <span class="text-accent">life good</span></h1>

            <p class="hero-lead">
                Compare products, get an instant quote, and manage your policies,
                premiums and claims &mdash; all in one place.
            </p>

            <div class="d-flex align-items-center gap-3 mt-4">
                @if (!isLoggedIn)
                {
                    <a asp-controller="Account" asp-action="Signup" class="btn btn-primary btn-lg">Get Started</a>
                    <a asp-controller="Account" asp-action="Login" class="text-accent fw-semibold">Sign in &rarr;</a>
                }
                else
                {
                    <a asp-controller="Products" asp-action="Index" class="btn btn-primary btn-lg">Browse products</a>
                }
            </div>
        </div>

        <div class="col-lg-6">
            <div class="hero-art">
                <span class="hero-dots"></span>
                <div class="hero-panel">
                    <span class="hero-badge">Best of<br />Services</span>
                    <h5 class="mb-2">Everything in one place</h5>
                    <p class="mb-0">Quotes, policies, premiums and claims &mdash; handled online.</p>
                </div>
            </div>
        </div>
    </div>
</section>
