@{
    ViewData["Title"] = "Home";
    var isLoggedIn = !string.IsNullOrEmpty(Context.Session.GetString(SessionKeys.AccessToken));
}

<div class="p-4 mb-4 bg-light rounded">
    <h1>Insurance Policy Management System</h1>
    <p class="lead">Browse products, request a quote, and manage your policies.</p>

    @if (!isLoggedIn)
    {
        <a asp-controller="Account" asp-action="Login" class="btn btn-primary">Sign in</a>
        <a asp-controller="Account" asp-action="Signup" class="btn btn-outline-secondary">Sign up</a>
    }
    else
    {
        <a asp-controller="Products" asp-action="Index" class="btn btn-primary">Browse products</a>
    }
</div>

<h4>How it works</h4>
<ol>
    <li>Create an account and fill in your customer profile.</li>
    <li>Browse the products and request a quote.</li>
    <li>Accept the quote you like.</li>
    <li>An underwriter reviews it and issues your policy.</li>
</ol>
