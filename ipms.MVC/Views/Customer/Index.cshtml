@model CustomerDto
@{
    ViewData["Title"] = "My profile";
}

<div class="page-head"><div><h2>My profile</h2><p class="page-sub">Your details are below. Change anything and save.</p></div></div>

<div>
        @* Posts to Edit as an UpdateCustomerDto - the field names match, so the
           values below both display the current profile and submit the edit. *@
        <form asp-action="Edit" method="post" class="form-panel">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="FirstName" class="form-label">First name</label>
                    <input asp-for="FirstName" class="form-control" maxlength="50" />
                    <span asp-validation-for="FirstName" class="text-danger small d-block"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="MiddleName" class="form-label">Middle name</label>
                    <input asp-for="MiddleName" class="form-control" />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="LastName" class="form-label">Last name</label>
                    <input asp-for="LastName" class="form-control" />
                </div>
            </div>

            <div class="row">
                @* Email is the sign-in identity, so it is shown but not editable.
                   Disabled means the browser does not post it back at all. *@
                <div class="col-md-6 mb-3">
                    <label asp-for="Email" class="form-label text-muted">Email</label>
                    <input asp-for="Email" class="form-control text-muted bg-body-secondary" disabled />
                    <span class="form-text">Your email is used to sign in and cannot be changed here.</span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="PhoneNumber" class="form-label">Phone number</label>
                    <input asp-for="PhoneNumber" class="form-control" maxlength="10" inputmode="numeric" placeholder="10-digit US number" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small d-block"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="DateOfBirth" class="form-label">Date of birth</label>
                    <input asp-for="DateOfBirth" type="date" class="form-control" />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Gender" class="form-label">Gender</label>
                    <select asp-for="Gender" asp-items="Html.GetEnumSelectList<CustomerGender>()" class="form-select"></select>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="MaritalStatus" class="form-label">Marital status</label>
                    <select asp-for="MaritalStatus" asp-items="Html.GetEnumSelectList<MaritalStatus>()" class="form-select"></select>
                </div>
            </div>

            <h5 class="mt-3">Address</h5>
            <div class="row">
                <div class="col-md-3 mb-3">
                    <label asp-for="Address.HouseNumber" class="form-label">House no.</label>
                    <input asp-for="Address.HouseNumber" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Address.StreetName" class="form-label">Street</label>
                    <input asp-for="Address.StreetName" class="form-control" />
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="Address.StreetSuffix" class="form-label">Suffix</label>
                    <input asp-for="Address.StreetSuffix" class="form-control" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-5 mb-3">
                    <label asp-for="Address.City" class="form-label">City</label>
                    <input asp-for="Address.City" class="form-control" />
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="Address.State" class="form-label">State</label>
                    <input asp-for="Address.State" class="form-control" />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Address.ZipCode" class="form-label">Zip code</label>
                    <input asp-for="Address.ZipCode" class="form-control" />
                </div>
            </div>

            <button type="submit" class="btn btn-teal">Save changes</button>
</form>
