@model PoliciesDto
@{
    ViewData["Title"] = "My policies";
}

<div class="page-head">
    <div>
        <h2>My policies</h2>
        <p class="page-sub">Click a policy to see its full details.</p>
    </div>
</div>

@if (Model.Total == 0)
{
    <div class="empty-state">
        <div class="es-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2 3 6v6c0 5.25 3.75 8.25 9 10 5.25-1.75 9-4.75 9-10V6z" />
            </svg>
        </div>
        <h5>No policies yet</h5>
        <p class="mb-0">A policy is created once an underwriter approves a quote you have accepted.</p>
    </div>
}
else
{
    <div class="panel">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Policy #</th>
                    <th>Product</th>
                    <th>Coverage</th>
                    <th>Premium</th>
                    <th>Start</th>
                    <th>End</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var policy in Model.Policies)
                {
                    <tr class="policy-row" style="cursor:pointer" data-policy-id="@policy.Id">
                        <td>@policy.PolicyNumber</td>
                        <td>@policy.ProductName</td>
                        <td>@policy.CoverageAmount.ToString("N0")</td>
                        <td>@policy.PremiumAmount.ToString("N2")</td>
                        <td>@policy.StartDate.ToString("yyyy-MM-dd")</td>
                        <td>@policy.EndDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @{
                                var pcls = policy.Status switch
                                {
                                    PolicyStatus.Active => "pill pill-green",
                                    PolicyStatus.Cancelled => "pill pill-red",
                                    PolicyStatus.Expired => "pill pill-grey",
                                    _ => "pill pill-amber"
                                };
                            }
                            <span class="@pcls">@policy.Status</span>
                        </td>
                        <td class="text-end text-nowrap" onclick="event.stopPropagation();">
                            <a class="btn btn-sm btn-outline-primary"
                               asp-controller="Payments" asp-action="Index"
                               asp-route-policyId="@policy.Id">Payments</a>
                            @if (policy.Status == PolicyStatus.Active)
                            {
                                <a class="btn btn-sm btn-outline-secondary"
                                   asp-controller="Claims" asp-action="Create"
                                   asp-route-policyId="@policy.Id">Claim</a>
                            }
                            @if (policy.Status != PolicyStatus.Cancelled)
                            {
                                <form asp-action="Renew" asp-route-id="@policy.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-teal">Renew</button>
                                </form>
                            }
                            @if (policy.Status == PolicyStatus.Active)
                            {
                                <button type="button" class="btn btn-sm btn-outline-secondary cancel-policy-btn"
                                        data-policy-id="@policy.Id" data-policy-number="@policy.PolicyNumber">
                                    Cancel
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="modal fade" id="policyModal" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Policy details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="policyModalBody"></div>
            </div>
        </div>
    </div>

    @* First confirmation: this modal asks for a reason. Second: a JS confirm(). *@
    <div class="modal fade" id="cancelModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form asp-action="Cancel" method="post"
                      onsubmit="return confirm('This permanently cancels the policy and cannot be undone. Cancel it?');">
                    <div class="modal-header">
                        <h5 class="modal-title">Cancel policy</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p>You are about to cancel policy <strong id="cancelPolicyNumber"></strong>.</p>
                        <input type="hidden" name="id" id="cancelPolicyId" />
                        <div class="mb-2">
                            <label class="form-label">Reason for cancelling</label>
                            <textarea name="cancellationReason" class="form-control" rows="2" required></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Keep policy</button>
                        <button type="submit" class="btn btn-danger">Cancel policy</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.querySelectorAll('.policy-row').forEach(function (row) {
            row.addEventListener('click', function () {
                var body = document.getElementById('policyModalBody');
                body.innerHTML = '<p class="text-muted">Loading...</p>';
                new bootstrap.Modal(document.getElementById('policyModal')).show();

                fetch('/Policies/Details/' + this.dataset.policyId)
                    .then(function (response) { return response.text(); })
                    .then(function (html) { body.innerHTML = html; })
                    .catch(function () {
                        body.innerHTML = '<p class="text-danger">Could not load this policy.</p>';
                    });
            });
        });

        document.querySelectorAll('.cancel-policy-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.getElementById('cancelPolicyId').value = this.dataset.policyId;
                document.getElementById('cancelPolicyNumber').textContent = this.dataset.policyNumber;
                new bootstrap.Modal(document.getElementById('cancelModal')).show();
            });
        });
    </script>
}
