@model AuthLoginDto
@{
    ViewData["Title"] = "Sign in";
}

<div class="auth-page">
    <div class="card auth-card shadow-sm">
        <div class="card-body p-4">
            <h3 class="text-center mb-4">Sign in</h3>

            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small d-block"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Password</label>
                    <div class="input-group">
                        <input asp-for="Password" type="password" class="form-control" />
                        <partial name="_PasswordEye" model="@("Password")" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small d-block"></span>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary">Sign in</button>
                </div>
                <p class="text-center mt-3 mb-0">
                    <a asp-action="Signup">Create an account</a>
                </p>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_PasswordToggle" />
}

