@model AuthSignupDto
@{
    ViewData["Title"] = "Sign up";
}

<div class="auth-page">
    <div class="card auth-card shadow-sm">
        <div class="card-body p-4">
            <h3 class="text-center mb-4">Create an account</h3>

            <form asp-action="Signup" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                <div class="mb-3">
                    <label asp-for="FirstName" class="form-label">First name</label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger small d-block"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="LastName" class="form-label">Last name</label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger small d-block"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small d-block"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PhoneNumber" class="form-label">Phone number</label>
                    <input asp-for="PhoneNumber" class="form-control" maxlength="10"
                           inputmode="numeric" placeholder="10-digit US number" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small d-block"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Password</label>
                    <div class="input-group">
                        <input asp-for="Password" type="password" class="form-control" />
                        <button class="btn btn-outline-secondary toggle-pw" type="button"
                                data-target="Password" tabindex="-1" aria-label="Show password">
                            @Html.Raw(EyeIcon)
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small d-block"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PasswordConfirm" class="form-label">Confirm password</label>
                    <div class="input-group">
                        <input asp-for="PasswordConfirm" type="password" class="form-control" />
                        <button class="btn btn-outline-secondary toggle-pw" type="button"
                                data-target="PasswordConfirm" tabindex="-1" aria-label="Show password">
                            @Html.Raw(EyeIcon)
                        </button>
                    </div>
                    <span asp-validation-for="PasswordConfirm" class="text-danger small d-block"></span>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary">Sign up</button>
                </div>
                <p class="text-center mt-3 mb-0">
                    <a asp-action="Login">I already have an account</a>
                </p>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_PasswordToggle" />
}

@functions {
    // Inline eye SVG (Bootstrap Icons "eye"), so no icon library is needed.
    const string EyeIcon =
        "<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' fill='currentColor' viewBox='0 0 16 16'>" +
        "<path d='M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.669 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z'/>" +
        "<path d='M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0'/></svg>";
}
