@model AuthSignupDto
@{
    ViewData["Title"] = "Sign up";
}

<div class="auth-page">
    <div class="card auth-card shadow-sm">
        <div class="card-body p-4">
            <h3 class="text-center mb-4">Create an account</h3>

            <form asp-action="Signup" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                <div class="mb-3">
                    <label asp-for="FirstName" class="form-label">First name</label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger small d-block"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="LastName" class="form-label">Last name</label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger small d-block"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small d-block"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PhoneNumber" class="form-label">Phone number</label>
                    <input asp-for="PhoneNumber" class="form-control" maxlength="10"
                           inputmode="numeric" placeholder="10-digit US number" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small d-block"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Password</label>
                    <div class="input-group">
                        <input asp-for="Password" type="password" class="form-control" />
                        <partial name="_PasswordEye" model="@("Password")" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small d-block"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PasswordConfirm" class="form-label">Confirm password</label>
                    <div class="input-group">
                        <input asp-for="PasswordConfirm" type="password" class="form-control" />
                        <partial name="_PasswordEye" model="@("PasswordConfirm")" />
                    </div>
                    <span asp-validation-for="PasswordConfirm" class="text-danger small d-block"></span>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary">Sign up</button>
                </div>
                <p class="text-center mt-3 mb-0">
                    <a asp-action="Login">I already have an account</a>
                </p>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_PasswordToggle" />
}

